# Database
DATABASE_URL=postgresql://spriteforge:spriteforge@localhost:5432/spriteforge

# OpenAI / ChatGPT
OPENAI_API_KEY=sk-...

# Storage Backend
STORAGE_BACKEND=local  # Options: local, s3, replit
STORAGE_LOCAL_PATH=/data/storage

# S3 (if STORAGE_BACKEND=s3)
S3_BUCKET=spriteforge-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=  # For S3-compatible services (Wasabi, etc)

# Replit (if STORAGE_BACKEND=replit)
REPLIT_OBJECT_STORAGE_TOKEN=

# Generation Settings
BATCH_SIZE=5
MAX_RETRY_ATTEMPTS=3
GENERATION_MODEL=dall-e-3
GENERATION_QUALITY=hd

# Post-processing
SPRITE_FORMAT=png
BACKGROUND_REMOVAL_ENABLED=true

# Atlas Packing
MAX_ATLAS_WIDTH=2048
MAX_ATLAS_HEIGHT=2048

# Logging
LOG_LEVEL=INFO

# Streamlit
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
